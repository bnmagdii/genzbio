rules_version = '2';
service cloud.firestore {
 match /databases/{database}/documents {

    // Global Safety Net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator' ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['admin', 'super_admin', 'moderator']))
      );
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin' ||
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles != null &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.roles.hasAny(['super_admin']))
      );
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Admins/Super Admins can write general fields; but ONLY Super Admins can write roles, bans, or verification badges
      allow write: if isSuperAdmin() || (
        isOwner(userId) && (
          resource == null ||
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'roles', 'verified', 'verificationBadgeId', 'verificationIcon', 'verifiedAt', 'verifiedBy', 'banned'])
        )
      ) || (
        isAdmin() && (
          resource != null &&
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['verified', 'verificationBadgeId', 'verificationIcon', 'verifiedAt', 'verifiedBy'])
        )
      );
    }

    // 2. Bios Collection
    match /bios/{bioId} {
      allow read: if true; // Public access to view bios

      allow create: if isSignedIn() 
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.id == bioId
        && isValidId(bioId)
        && request.resource.data.username is string 
        && request.resource.data.username.size() >= 2
        && request.resource.data.username.size() <= 40;

      allow update: if isSuperAdmin() || isAdmin()
        || (isSignedIn() && resource.data.ownerId == request.auth.uid && request.resource.data.ownerId == request.auth.uid)
        || request.resource.data.diff(resource.data).affectedKeys().hasOnly(['visitorCount', 'emojiReactions']);

      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // 3. Links Collection
    match /links/{linkId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && (resource == null || resource.data.ownerId == request.auth.uid) && request.resource.data.ownerId == request.auth.uid);
    }

    // 4. Analytics Collection
    match /analytics/{analyticId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if true; 
      allow update, delete: if false;
    }

    // 5. Notifications Collection
    match /notifications/{notificationId} {
      allow read, update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
    }

    // 6. Themes Collection
    match /themes/{themeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // 7. Messages Collection
    match /messages/{messageId} {
      allow read, delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
      allow create: if true; 
    }

    // 8. Guestbook Collection
    match /guestbook/{guestbookId} {
      allow read: if true;
      allow create: if true; 
      allow update, delete: if isAdmin() || (isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.userId == request.auth.uid));
    }

    // 9. Stories Collection
    match /stories/{storyId} {
      allow read: if true;
      allow create: if isAdmin() || (isSignedIn() && request.resource.data.ownerId == request.auth.uid);
      allow delete: if isAdmin() || (isSignedIn() && resource.data.ownerId == request.auth.uid);
    }

    // 10. Settings Collection
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid) && request.resource.data.userId == request.auth.uid);
    }

    // 11. Custom Verification Badges Collection
    match /verification_badges/{badgeId} {
      allow read: if true;
      allow create, update, delete: if isSuperAdmin() || isAdmin();
    }

    // 12. Security Reports Collection
    match /reports/{reportId} {
      allow read, create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // 13. AI Generated Images
    match /ai_images/{imageId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // 14. AI Generated Bios
    match /ai_bios/{bioId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // 15. Verification Action Logs Collection
    match /verification_logs/{logId} {
      allow read, create: if isSuperAdmin();
      allow update, delete: if false;
    }
  }
}
